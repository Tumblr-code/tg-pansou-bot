# Telegram Bot 配置
# 从 @BotFather 获取的 Bot Token（格式：123456789:ABCdefGHIjklMNOpqrsTUVwxyz）
TG_BOT_TOKEN=your_bot_token_here

# Pansou API 配置
# pansou API 服务地址（例如：http://localhost:8888）
PANSOU_API_URL=http://localhost:8888
# pansou API 认证 Token（如果启用了认证）
PANSOU_API_TOKEN=

# 代理配置（可选）
# HTTP 代理地址，如：http://127.0.0.1:1080
HTTP_PROXY=
# HTTPS 代理地址
HTTPS_PROXY=

# 搜索配置
# 默认搜索结果限制
DEFAULT_RESULT_LIMIT=10
# 最大搜索结果限制
MAX_RESULT_LIMIT=20
# 搜索超时时间（秒）
SEARCH_TIMEOUT=30

# 日志配置
# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 速率限制配置（可选）
# 每个用户每分钟最大请求数
RATE_LIMIT_PER_MINUTE=10

# 管理员配置（建议填写）
# 管理员ID列表，逗号分隔，如：123456789,987654321
# 必须填写你自己的 Telegram 数字 ID，否则 /status /settings /filter /types /refresh /update 都不会开放
# 普通用户只能使用简单的搜索功能
ADMIN_IDS=

# HTTP API 配置（可选）
# 建议只监听本机，然后由 Nginx / Cloudflare Tunnel 转发
HTTP_API_HOST=127.0.0.1
HTTP_API_PORT=8090
# 建议填写一个随机字符串，保护公开搜索接口
HTTP_API_TOKEN=
